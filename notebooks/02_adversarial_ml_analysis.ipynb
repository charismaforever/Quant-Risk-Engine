 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 2: Adversarial ML Threat Analysis for Quantitative Trading\n",
    "\n",
    "Explores adversarial attack surfaces across different trading strategy types\n",
    "and model architectures, with defense ROI analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "\n",
    "from core.scenario import AdversarialAIParams\n",
    "from ai_adversarial.attack_simulator import AdversarialAttackSimulator, ARCHITECTURE_EVASION_VULNERABILITY\n",
    "from ai_adversarial.trading_algo_threat import TradingAlgoThreatModel, STRATEGY_ATTACK_SURFACES\n",
    "from ai_adversarial.defense_analyzer import DefenseAnalyzer\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "print('Modules loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Attack Surface Heatmap by Strategy Type"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "strategies = list(STRATEGY_ATTACK_SURFACES.keys())\n",
    "attack_vectors = ['signal_noise_injection', 'feature_manipulation', 'latency_exploitation']\n",
    "\n",
    "z = [[STRATEGY_ATTACK_SURFACES[s][v] for v in attack_vectors] for s in strategies]\n",
    "\n",
    "fig = go.Figure(data=go.Heatmap(\n",
    "    z=z, x=attack_vectors, y=strategies,\n",
    "    colorscale='RdYlGn_r', text=[[f'{val:.2f}' for val in row] for row in z],\n",
    "    texttemplate='%{text}'\n",
    "))\n",
    "fig.update_layout(\n",
    "    title='Adversarial Attack Vulnerability by Strategy Type',\n",
    "    xaxis_title='Attack Vector',\n",
    "    yaxis_title='Trading Strategy'\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Defense ROI Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "analyzer = DefenseAnalyzer(baseline_annual_loss_usd=5_000_000)\n",
    "rois = analyzer.analyze_all()\n",
    "\n",
    "df = pd.DataFrame([\n",
    "    {\n",
    "        'Defense': r.defense_name,\n",
    "        'Annual Cost ($K)': r.annual_cost_usd / 1000,\n",
    "        'Loss Avoided ($K)': r.expected_annual_loss_avoided_usd / 1000,\n",
    "        'ROI Ratio': r.roi_ratio,\n",
    "        'Payback (months)': r.payback_months,\n",
    "    }\n",
    "    for r in rois\n",
    "])\n",
    "\n",
    "fig = px.scatter(\n",
    "    df, x='Annual Cost ($K)', y='Loss Avoided ($K)',\n",
    "    size='ROI Ratio', color='ROI Ratio', hover_data=['Defense', 'Payback (months)'],\n",
    "    title='Defense Investment ROI Landscape',\n",
    "    color_continuous_scale='RdYlGn'\n",
    ")\n",
    "fig.add_shape(type='line', x0=0, y0=0, x1=df['Annual Cost ($K)'].max(), y1=df['Annual Cost ($K)'].max(),\n",
    "              line=dict(dash='dash', color='gray'))\n",
    "fig.show()\n",
    "print(df.to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Attack Success Probability Distribution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "architectures = list(ARCHITECTURE_EVASION_VULNERABILITY.keys())\n",
    "scores = []\n",
    "\n",
    "for arch in architectures:\n",
    "    params = AdversarialAIParams(model_architecture=arch, defense_mechanisms=[])\n",
    "    sim = AdversarialAttackSimulator(params, rng=np.random.default_rng(42))\n",
    "    score, sharpe = sim.simulate()\n",
    "    scores.append({'Architecture': arch, 'Threat Score': score, 'Sharpe Impact': sharpe})\n",
    "\n",
    "df = pd.DataFrame(scores).sort_values('Threat Score', ascending=False)\n",
    "\n",
    "fig = px.bar(\n",
    "    df, x='Architecture', y='Threat Score', color='Threat Score',\n",
    "    title='Adversarial Threat Score by Model Architecture (No Defenses)',\n",
    "    color_continuous_scale='RdYlGn_r'\n",
    ")\n",
    "fig.show()"
   ]
  }
 ],
