   "source": [
    "# Notebook 3: Cyber-Adjusted Portfolio Risk Simulation\n",
    "\n",
    "Full pipeline demonstration: run all four modules, produce CyberVaR/CVaR\n",
    "metrics, and compare baseline vs. cyber-adjusted return distributions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import plotly.graph_objects as go\n",
    "import plotly.figure_factory as ff\n",
    "\n",
    "from core.scenario import Scenario\n",
    "from core.simulation_engine import SimulationEngine\n",
    "from financial_risk.monte_carlo import CyberAdjustedMonteCarlo\n",
    "from financial_risk.risk_metrics import RiskMetrics\n",
    "from financial_risk.portfolio_stress import PortfolioStressTester\n",
    "from financial_risk.cyber_var import CyberVaRModel\n",
    "\n",
    "print('All modules loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Full Simulation — Baseline Scenario"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "scenario = Scenario.from_yaml('config/scenarios/hedge_fund_baseline.yaml')\n",
    "engine = SimulationEngine(scenario, n_simulations=20_000, seed=42)\n",
    "results = engine.run()\n",
    "print(results.summary())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Return Distribution: Baseline vs Cyber-Adjusted"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from financial_risk.monte_carlo import CyberAdjustedMonteCarlo\n",
    "from core.scenario import FinancialRiskParams\n",
    "\n",
    "params = FinancialRiskParams(n_simulations=20_000)\n",
    "rng = np.random.default_rng(42)\n",
    "\n",
    "# Baseline: no cyber shocks\n",
    "mc_baseline = CyberAdjustedMonteCarlo(\n",
    "    params=params, quantum_risk_score=0.0,\n",
    "    adversarial_threat_score=0.0, threat_likelihood=0.0,\n",
    "    n_simulations=20_000, rng=rng\n",
    ")\n",
    "baseline_returns = mc_baseline.run()\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "mc_cyber = CyberAdjustedMonteCarlo(\n",
    "    params=params,\n",
    "    quantum_risk_score=results.quantum_risk_score,\n",
    "    adversarial_threat_score=results.adversarial_threat_score,\n",
    "    threat_likelihood=results.threat_likelihood,\n",
    "    n_simulations=20_000, rng=rng\n",
    ")\n",
    "cyber_returns = mc_cyber.run()\n",
    "\n",
    "fig = ff.create_distplot(\n",
    "    [baseline_returns, cyber_returns],\n",
    "    group_labels=['Baseline (no cyber)', 'Cyber-Adjusted'],\n",
    "    bin_size=0.005, show_rug=False\n",
    ")\n",
    "\n",
    "# Add VaR lines\n",
    "for ret, label, color in [\n",
    "    (baseline_returns, 'Baseline VaR 99%', 'blue'),\n",
    "    (cyber_returns, 'Cyber VaR 99%', 'red')\n",
    "]:\n",
    "    var = float(np.percentile(ret, 1))\n",
    "    fig.add_vline(x=var, line_dash='dash', line_color=color,\n",
    "                  annotation_text=f'{label}: {var:.1%}')\n",
    "\n",
    "fig.update_layout(\n",
    "    title='Portfolio Return Distribution: Baseline vs Cyber-Adjusted',\n",
    "    xaxis_title='Annual Portfolio Return',\n",
    "    xaxis=dict(tickformat='.0%')\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Scenario Comparison: Well-Defended vs High Quantum Risk"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "scenarios_to_compare = [\n",
    "    ('Baseline', 'config/scenarios/hedge_fund_baseline.yaml'),\n",
    "    ('Well Defended', 'config/scenarios/well_defended.yaml'),\n",
    "    ('High Quantum Risk', 'config/scenarios/high_quantum_risk.yaml'),\n",
    "]\n",
    "\n",
    "comparison_data = []\n",
    "for name, path in scenarios_to_compare:\n",
    "    sc = Scenario.from_yaml(path)\n",
    "    r = SimulationEngine(sc, n_simulations=5_000, seed=42).run()\n",
    "    comparison_data.append({\n",
    "        'Scenario': name,\n",
    "        'Quantum Risk Score': r.quantum_risk_score,\n",
    "        'Adversarial Threat Score': r.adversarial_threat_score,\n",
    "        'Threat Likelihood': r.threat_likelihood,\n",
    "        'CyberVaR (99%)': r.cyber_var,\n",
    "        'CyberCVaR (99%)': r.cyber_cvar,\n",
    "        'Sharpe Impact': r.sharpe_impact,\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(comparison_data)\n",
    "print(df.to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Cyber Stress Test — All Scenarios"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "tester = PortfolioStressTester(portfolio_value_usd=500_000_000, rng=np.random.default_rng(42))\n",
    "stress_results = tester.run_all_scenarios()\n",
    "\n",
    "df_stress = pd.DataFrame([\n",
    "    {\n",
    "        'Scenario': r.scenario_name,\n",
    "        'Return Impact': r.portfolio_return_impact,\n",
    "        'Dollar Loss ($M)': r.dollar_loss_usd / 1e6,\n",
    "        'Annual Probability': r.probability,\n",
    "        'Expected Annual Loss ($M)': r.expected_annual_loss_usd / 1e6,\n",
    "        'Recovery (months)': r.recovery_months,\n",
    "    }\n",
    "    for r in stress_results\n",
    "])\n",
    "\n",
    "fig = px.bar(\n",
    "    df_stress, x='Scenario', y='Expected Annual Loss ($M)',\n",
    "    color='Annual Probability', title='Expected Annual Loss by Cyber Stress Scenario',\n",
    "    color_continuous_scale='Reds'\n",
    ")\n",
    "fig.show()\n",
    "print(df_stress.to_string(index=False))"
   ]
  }
 ],
