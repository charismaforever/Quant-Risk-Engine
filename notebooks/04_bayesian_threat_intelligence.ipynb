   "source": [
    "# Notebook 4: Bayesian Threat Intelligence Analysis\n",
    "\n",
    "Demonstrates the `threat_intel` module: Bayesian updating of attack\n",
    "likelihoods, threat actor profiling, and sector risk mapping using\n",
    "MITRE ATT&CK frequency data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "from scipy import stats\n",
    "\n",
    "from core.scenario import ThreatIntelParams\n",
    "from threat_intel.ttp_engine import TTPEngine\n",
    "from threat_intel.bayesian_updater import BayesianUpdater\n",
    "from threat_intel.sector_mapper import (\n",
    "    SECTOR_BASE_RATES, THREAT_ACTOR_PROFILES, SECTOR_TOP_TTPS\n",
    ")\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "print('Modules loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Prior vs Posterior Visualization — Bayesian Update\n",
    "\n",
    "Visualize how observing new threat incidents updates our belief about\n",
    "attack probability for FIN7 targeting financial services."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "updater = BayesianUpdater(rng=np.random.default_rng(42))\n",
    "\n",
    "# FIN7 vs financial services: strong prior from history\n",
    "alpha_prior, beta_prior = 8.8, 1.2  # Prior mean = 0.88\n",
    "\n",
    "# Simulate sequential incident observations\n",
    "observation_batches = [(3, 4), (2, 3), (4, 5), (1, 2)]\n",
    "x = np.linspace(0, 1, 300)\n",
    "\n",
    "fig = go.Figure()\n",
    "\n",
    "# Plot prior\n",
    "prior_pdf = stats.beta.pdf(x, alpha_prior, beta_prior)\n",
    "fig.add_trace(go.Scatter(x=x, y=prior_pdf, name='Prior', line=dict(dash='dash', color='gray')))\n",
    "\n",
    "# Sequential updates\n",
    "alpha, beta = alpha_prior, beta_prior\n",
    "colors = ['blue', 'green', 'orange', 'red']\n",
    "for i, (k, n) in enumerate(observation_batches):\n",
    "    result = updater.update_full(alpha, beta, k, n)\n",
    "    alpha, beta = result.alpha_posterior, result.beta_posterior\n",
    "    post_pdf = stats.beta.pdf(x, alpha, beta)\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=x, y=post_pdf,\n",
    "        name=f'After batch {i+1} ({k}/{n} successes)',\n",
    "        line=dict(color=colors[i])\n",
    "    ))\n",
    "\n",
    "fig.update_layout(\n",
    "    title='Bayesian Updating: FIN7 Attack Probability (Financial Services)',\n",
    "    xaxis_title='Attack Success Probability p',\n",
    "    yaxis_title='Density'\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Threat Actor Affinity Heatmap by Sector"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "actors = list(THREAT_ACTOR_PROFILES.keys())\n",
    "sectors = list(SECTOR_BASE_RATES.keys())\n",
    "\n",
    "z = [\n",
    "    [THREAT_ACTOR_PROFILES[actor].get(sector, 0.10) for sector in sectors]\n",
    "    for actor in actors\n",
    "]\n",
    "\n",
    "fig = go.Figure(data=go.Heatmap(\n",
    "    z=z, x=sectors, y=actors,\n",
    "    colorscale='RdYlGn_r',\n",
    "    text=[[f'{v:.2f}' for v in row] for row in z],\n",
    "    texttemplate='%{text}'\n",
    "))\n",
    "fig.update_layout(\n",
    "    title='Threat Actor Targeting Affinity by Industry Sector',\n",
    "    xaxis_title='Sector', yaxis_title='Threat Actor'\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Sector Risk Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = []\n",
    "for sector, base_rate in SECTOR_BASE_RATES.items():\n",
    "    params = ThreatIntelParams(\n",
    "        sector=sector,\n",
    "        threat_actors=['FIN7', 'Lazarus', 'APT29'],\n",
    "        prior_breach_probability=base_rate\n",
    "    )\n",
    "    engine = TTPEngine(params, rng=np.random.default_rng(42))\n",
    "    matrix = engine.build_likelihood_matrix()\n",
    "    results.append({\n",
    "        'Sector': sector,\n",
    "        'Base Rate': base_rate,\n",
    "        'Posterior Likelihood': matrix.overall_likelihood,\n",
    "        'Risk Multiplier': matrix.sector_risk_score,\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(results).sort_values('Posterior Likelihood', ascending=False)\n",
    "\n",
    "fig = px.bar(\n",
    "    df, x='Sector', y=['Base Rate', 'Posterior Likelihood'],\n",
    "    barmode='group',\n",
    "    title='Base Rate vs Bayesian Posterior Breach Likelihood by Sector',\n",
    "    color_discrete_map={'Base Rate': 'lightblue', 'Posterior Likelihood': 'steelblue'}\n",
    ")\n",
    "fig.update_layout(yaxis=dict(tickformat='.0%'))\n",
    "fig.show()"
   ]
  }
 ],
